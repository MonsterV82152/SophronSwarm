{
  "name": "sophron-swarm",
  "version": "0.1.0",
  "private": true,
  "description": "SophronSwarm V3 — modular, token-optimized, multi-agent CLI",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "sophron": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.1",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
