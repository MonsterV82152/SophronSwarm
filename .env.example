# ── SophronSwarm V3 environment ──────────────────────────────────────────────
# Copy to .env and fill in the providers you use. All three are OpenAI-compatible.

# OpenRouter (cloud router — gives access to many models behind one key)
OPENROUTER_API_KEY=
# Default OpenRouter model id, e.g. anthropropic/claude-sonnet-4
OPENROUTER_DEFAULT_MODEL=

# Ollama (local, offline) — no key required; OLLAMA_BASE_URL is optional
OLLAMA_BASE_URL=http://localhost:11434/v1
# Default local model tag, e.g. llama3.2:1b
OLLAMA_DEFAULT_MODEL=

# z.ai (OpenAI-compatible coding endpoint)
ZAI_API_KEY=
ZAI_DEFAULT_MODEL=

# ── Optional runtime knobs ───────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
SOPHRON_LOG_LEVEL=info
# Workspace root (defaults to current working directory)
SOPHRON_WORKSPACE=
